<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context="com.wyz.test.ui.DemoActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container_navi"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#ffeecc"/>

    <com.wyz.emlibrary.custom.RoundedCardView
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/transparent"
        app:cardElevation="0dp"
        app:rcvTopLeftRadius="40dp"
        app:rcvTopRightRadius="12dp"
        app:rcvBottomLeftRadius="40dp"
        app:rcvBottomRightRadius="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.wyz.emlibrary.custom.GravityCropImageView
            android:id="@+id/iv_pic"
            android:layout_width="150dp"
            android:layout_height="250dp"
            app:gciHorizontal="start"
            app:gciVertical="top"
            android:src="@drawable/pic_test1" />
    </com.wyz.emlibrary.custom.RoundedCardView>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_perm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="权限获取"/>

        <Button
            android:id="@+id/btn_start_scan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="开始扫描"
            android:layout_marginTop="30dp"/>

        <Button
            android:id="@+id/btn_end_scan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="结束扫描"
            android:layout_marginTop="30dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>